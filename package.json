{
  "name": "anydoor",
  "version": "1.0.0",
  "private": true,
  "description": "AnyDoor - 本地 AI 模型网关，一键连接 Claude Code / Codex 到任意大模型",
  "main": "electron/dist/main.js",
  "scripts": {
    "build": "pnpm exec concurrently --kill-others-on-fail --kill-signal SIGKILL -n lint,tsc,web,weapp,tt,server -c red,blue,green,yellow,cyan,magenta \"pnpm lint:build\" \"pnpm tsc\" \"pnpm build:web\" \"pnpm build:weapp\" \"pnpm build:tt\" \"pnpm build:server\"",
    "build:pack": "pnpm exec concurrently --kill-others-on-fail --kill-signal SIGKILL -n weapp,tt -c yellow,cyan \"pnpm build:weapp\" \"pnpm build:tt\"",
    "build:server": "cd server && pnpm build",
    "build:tt": "taro build --type tt",
    "build:weapp": "taro build --type weapp",
    "build:web": "taro build --type h5",
    "build:electron": "node electron/build.js",
    "build:desktop": "cd desktop && pnpm build && cd .. && pnpm build:server && node scripts/bundle-server.js && pnpm build:electron && npx electron-builder --mac --arm64 && node scripts/verify-build.js",
    "build:desktop:intel": "cd desktop && pnpm build && cd .. && pnpm build:server && node scripts/bundle-server.js && pnpm build:electron && npx electron-builder --mac --x64 && node scripts/verify-build.js",
    "build:desktop:all": "cd desktop && pnpm build && cd .. && pnpm build:server && node scripts/bundle-server.js && pnpm build:electron && npx electron-builder --mac --arm64 --x64 && node scripts/verify-build.js",
    "dev": "pnpm exec concurrently --kill-others --kill-signal SIGKILL -n web,server -c blue,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:desktop": "cd desktop && pnpm install && pnpm dev & cd .. && pnpm dev:server & sleep 5 && pnpm build:electron && npx electron .",
    "dev:server": "cd server && pnpm dev",
    "dev:tt": "taro build --type tt --watch",
    "dev:weapp": "taro build --type weapp --watch",
    "dev:web": "taro build --type h5 --watch",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "weapp-tw patch",
    "kill:all": "pkill -9 -f 'concurrently' 2>/dev/null || true; pkill -9 -f 'nest start' 2>/dev/null || true; pkill -9 -f 'taro build' 2>/dev/null || true; pkill -9 -f 'node.*dev' 2>/dev/null || true; echo 'All dev processes cleaned'",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx,css}\"",
    "lint:build": "eslint \"src/**/*.{js,jsx,ts,tsx,css}\" --max-warnings=0 --quiet",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx,css}\" --fix",
    "new": "taro new",
    "preview:tt": "taro build --type tt --preview",
    "preview:weapp": "taro build --type weapp --preview",
    "tsc": "npx tsc --noEmit --skipLibCheck",
    "validate": "pnpm exec concurrently --kill-others-on-fail --kill-signal SIGKILL -n lint,tsc -c red,blue \"pnpm lint:build\" \"pnpm tsc\""
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,css}": [
      "eslint"
    ]
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@tarojs/components": "4.1.9",
    "@tarojs/helper": "4.1.9",
    "@tarojs/plugin-framework-react": "4.1.9",
    "@tarojs/plugin-platform-h5": "4.1.9",
    "@tarojs/plugin-platform-tt": "4.1.9",
    "@tarojs/plugin-platform-weapp": "4.1.9",
    "@tarojs/react": "4.1.9",
    "@tarojs/runtime": "4.1.9",
    "@tarojs/shared": "4.1.9",
    "@tarojs/taro": "4.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react-taro": "^1.4.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.1",
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tarojs/cli": "4.1.9",
    "@tarojs/plugin-generator": "4.1.9",
    "@tarojs/plugin-mini-ci": "^4.1.9",
    "@tarojs/vite-runner": "4.1.9",
    "@types/minimatch": "^5",
    "@types/node": "^24",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-preset-taro": "4.1.9",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.1.9",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.4.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "less": "^4.2.0",
    "lint-staged": "^16.1.2",
    "miniprogram-ci": "^2.1.26",
    "only-allow": "^1.2.2",
    "postcss": "^8.5.6",
    "react-refresh": "^0.14.0",
    "stylelint": "^16.4.0",
    "stylelint-config-standard": "^38.0.0",
    "tailwindcss": "^4.1.18",
    "terser": "^5.30.4",
    "tt-ide-cli": "^0.1.31",
    "typescript": "^5.4.5",
    "vite": "^4.2.0",
    "weapp-tailwindcss": "^4.10.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@tarojs/plugin-mini-ci@4.1.9": "patches/@tarojs__plugin-mini-ci@4.1.9.patch"
    }
  },
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "Less",
    "framework": "React"
  },
  "build": {
    "appId": "com.anydoor.gateway",
    "productName": "AnyDoor",
    "afterPack": "./scripts/afterPack.js",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "server-bundle/**/*",
      "dist-desktop/**/*",
      "electron/assets/**/*",
      "!server",
      "!src",
      "!release"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
