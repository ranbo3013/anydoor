<svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1"/>
      <stop offset="100%" style="stop-color:#8b5cf6"/>
    </linearGradient>
    <linearGradient id="door" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fbbf24"/>
      <stop offset="100%" style="stop-color:#f59e0b"/>
    </linearGradient>
  </defs>
  <!-- 背景 -->
  <rect width="32" height="32" rx="7.04" fill="url(#bg)"/>
  <!-- 门框 -->
  <rect x="8" y="3.2" width="16" height="24" rx="1.28" fill="url(#door)" stroke="#d97706" stroke-width="0.64"/>
  <!-- 门板分割线 -->
  <line x1="16" y1="3.2" x2="16" y2="27.2" stroke="#d97706" stroke-width="0.48"/>
  <!-- 左门把手 -->
  <circle cx="14.08" cy="16" r="0.96" fill="#92400e"/>
  <!-- 右门把手 -->
  <circle cx="17.92" cy="16" r="0.96" fill="#92400e"/>
  <!-- 光效 (任意门的光芒) -->
  <ellipse cx="16" cy="27.2" rx="6.4" ry="0.96" fill="#fef3c7" opacity="0.6"/>
  <!-- 星星装饰 -->
  <circle cx="4.8" cy="8" r="0.64" fill="#fef3c7" opacity="0.8"/>
  <circle cx="27.2" cy="6.4" r="0.48" fill="#fef3c7" opacity="0.6"/>
  <circle cx="3.2" cy="19.2" r="0.384" fill="#fef3c7" opacity="0.5"/>
  <circle cx="28.8" cy="17.6" r="0.576" fill="#fef3c7" opacity="0.7"/>
</svg>